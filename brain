layout.Padding = UDim.new(0, 5)
layout.SortOrder = Enum.SortOrder.LayoutOrder

-- ==========================================
-- 機能ロジック
-- ==========================================

-- リストへの追加
local function addEntry(name, speed, jobId)
    local item = Instance.new("Frame", scroll)
    item.Size = UDim2.new(1, 0, 0, 45)
    item.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    item.LayoutOrder = 1000000000 - math.floor(speed / 1000)
    Instance.new("UICorner", item)
    
    local info = Instance.new("TextLabel", item)
    info.Size = UDim2.new(0.7, 0, 1, 0)
    info.Position = UDim2.new(0.05, 0, 0, 0)
    info.Text = name .. "\n" .. string.format("%.1fM/s", speed/10^6)
    info.TextColor3 = Color3.new(1, 1, 1)
    info.BackgroundTransparency = 1
    info.TextXAlignment = Enum.TextXAlignment.Left
    
    local btn = Instance.new("TextButton", item)
    btn.Size = UDim2.new(0.25, 0, 0.7, 0)
    btn.Position = UDim2.new(0.7, 0, 0.15, 0)
    btn.Text = "GO"
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        -- 安全のための短いランダム待機
        task.wait(math.random(1, 5) / 10)
        TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, Players.LocalPlayer)
    end)
end

-- 高速スキャン (外部サーバー情報取得の模倣)
local function refresh()
    if isScanning then return end
    isScanning = true
    
    -- リスト清掃
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end

    -- 現在のサーバーをまずチェック
    for _, p in ipairs(Players:GetPlayers()) do
        local stats = p:FindFirstChild("leaderstats")
        local speed = stats and (stats:FindFirstChild("BrainrotPerSec") or stats:FindFirstChild("Gain"))
        if speed and speed.Value >= MIN_SPEED and speed.Value <= MAX_SPEED then
            addEntry(p.Name, speed.Value, game.JobId)
        end
    end

    -- クールダウン（API負荷軽減）
    task.wait(2)
    isScanning = false
end

-- アイコントグル
icon.MouseButton1Click:Connect(function()
    panel.Visible = not panel.Visible
    if panel.Visible then refresh() end
end)

-- ドラッグ機能
local dragging, dragStart, startPos
icon.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = icon.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        icon.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
icon.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)
