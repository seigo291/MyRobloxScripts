-- 数値をカンマ区切り（●,●M/s形式）にする関数
local function formatDisplay(val)
    local n = tonumber(val) or 0
    local suffix = "/s"
    local result = ""
    
    if n >= 1e9 then
        result = string.format("%.1f", n/1e9)
        suffix = "B/s"
    elseif n >= 1e6 then
        result = string.format("%.1f", n/1e6)
        suffix = "M/s"
    elseif n >= 1e3 then
        result = string.format("%.1f", n/1e3)
        suffix = "K/s"
    else
        result = string.format("%.1f", n)
    end
    
    -- カンマ挿入
    local left, right = result:match("^(%d+)(%.?%d*)$")
    left = left:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    return "$" .. left .. right .. suffix
end

-- プレイヤーから数値を根こそぎ探す
local function getPowerValue(p)
    local targets = {"BrainrotPerSec", "Gain", "PerSec", "Cash", "Income"}
    -- leaderstatsを優先
    local ls = p:FindFirstChild("leaderstats")
    if ls then
        for _, t in pairs(targets) do
            local v = ls:FindFirstChild(t)
            if v and v:IsA("ValueBase") then return v.Value end
        end
    end
    -- プレイヤー直下も探す
    for _, obj in pairs(p:GetChildren()) do
        if obj:IsA("NumberValue") or obj:IsA("IntValue") then
            for _, t in pairs(targets) do
                if obj.Name:find(t) then return obj.Value end
            end
        end
    end
    return 0
end

