local function createRefreshBtn(parent, text)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.9, 0, 0, 30)
    btn.Position = UDim2.new(0.05, 0, 1, -40)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextSize = 12
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    return btn
end

local refreshScan = createRefreshBtn(scanPage, "SCAN RELOAD")
local refreshServ = createRefreshBtn(servPage, "SERVER RELOAD")

local function addEntry(parent, text)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, -5, 0, 35)
    f.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Instance.new("UICorner", f)
    local t = Instance.new("TextLabel", f)
    t.Size = UDim2.new(1, -10, 1, 0)
    t.Position = UDim2.new(0, 5, 0, 0)
    t.BackgroundTransparency = 1
    t.Text = text
    t.TextColor3 = Color3.new(1, 1, 1)
    t.TextSize = 10
    t.TextXAlignment = Enum.TextXAlignment.Left
    return f
end

-- ロジック
local function doScan()
    for _, v in pairs(scanScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p == game.Players.LocalPlayer then continue end
        local stats = p:FindFirstChild("leaderstats")
        local val = stats and (stats:FindFirstChild("BrainrotPerSec") or stats:FindFirstChild("Gain") or stats:FindFirstChild("Cash"))
        local score = val and tostring(val.Value) or "---"
        addEntry(scanScroll, p.Name .. " : " .. score)
    end
end

local function doServers()
    for _, v in pairs(servScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local success, res = pcall(function()
        return game:GetService("HttpService"):JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=25"))
    end)
    if success and res.data then
        for _, s in pairs(res.data) do
            if s.playing >= s.maxPlayers then continue end
            local entry = addEntry(servScroll, s.playing .. "/" .. s.maxPlayers .. " (" .. (s.ping or "?") .. "ms)")
            local j = Instance.new("TextButton", entry)
            j.Size = UDim2.new(0.3, 0, 0.7, 0)
            j.Position = UDim2.new(0.65, 0, 0.15, 0)
            j.Text = "JOIN"
            j.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
            j.TextColor3 = Color3.new(1, 1, 1)
            Instance.new("UICorner", j)
            j.MouseButton1Click:Connect(function() game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, s.id) end)
        end
    end
end

tabScan.MouseButton1Click:Connect(function() scanPage.Visible = true; servPage.Visible = false; doScan() end)
tabServ.MouseButton1Click:Connect(function() scanPage.Visible = false; servPage.Visible = true; doServers() end)
refreshScan.MouseButton1Click:Connect(doScan)
refreshServ.MouseButton1Click:Connect(doServers)

doScan()
