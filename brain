local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

-- ==========================================
-- 設定エリア
-- ==========================================
local MIN_SPEED = 10 * 10^6
local MAX_SPEED = 100 * 10^6
local ICON_IMAGE = "rbxassetid://6031093116" -- 雷マーク
local isScanning = false -- 二重実行防止用

-- ==========================================
-- GUI作成
-- ==========================================
local screenGui = Instance.new("ScreenGui", game.CoreGui)
screenGui.Name = "SafeBrainrotScanner"

-- 雷アイコン
local icon = Instance.new("ImageButton", screenGui)
icon.Size = UDim2.new(0, 60, 0, 60)
icon.AnchorPoint = Vector2.new(1, 0.5)
icon.Position = UDim2.new(1, -10, 0.5, 0)
icon.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
icon.Image = ICON_IMAGE
icon.ImageColor3 = Color3.fromRGB(255, 255, 0)
local iconCorner = Instance.new("UICorner", icon)
iconCorner.CornerRadius = UDim.new(1, 0)
Instance.new("UIStroke", icon).Color = Color3.new(1, 1, 1)

-- パネル
local panel = Instance.new("Frame", screenGui)
panel.Size = UDim2.new(0.25, 0, 0.5, 0)
panel.AnchorPoint = Vector2.new(1, 0.5)
panel.Position = UDim2.new(1, -80, 0.5, 0)
panel.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
panel.Visible = false
Instance.new("UICorner", panel)

local scroll = Instance.new("ScrollingFrame", panel)
scroll.Size = UDim2.new(0.9, 0, 0.85, 0)
scroll.Position = UDim2.new(0.05, 0, 0.1, 0)
