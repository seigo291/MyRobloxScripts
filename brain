-- 共通ロジック
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local function runScan()
    for _, v in pairs(scanScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local minV = tonumber(minIn.Text) or 0
    local found = 0
    for _, p in ipairs(game.Players:GetPlayers()) do
        local s = p:FindFirstChild("leaderstats") and (p.leaderstats:FindFirstChild("Gain") or p.leaderstats:FindFirstChild("Cash"))
        if s and tonumber(tostring(s.Value):gsub("[^%d%.]", "")) >= minV then
            found = found + 1
            local f = Instance.new("Frame", scanScroll)
            f.Size = UDim2.new(1, 0, 0, 30)
            f.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            local t = Instance.new("TextLabel", f)
            t.Size = UDim2.new(1, -5, 1, 0)
            t.Text = p.Name .. ": " .. s.Value
            t.TextColor3 = Color3.new(1, 1, 1)
            t.TextSize = 9
            t.BackgroundTransparency = 1
        end
    end
    if found == 0 and _G.AutoScanEnabled then
        local res = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=50"))
        for _, s in pairs(res.data) do if s.playing < s.maxPlayers and s.id ~= game.JobId then TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id) break end end
    end
end

autoBtn.MouseButton1Click:Connect(function()
