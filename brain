-- 6. 便利関数（数値変換）
local function formatVal(v)
    local n = tonumber(v) or 0
    local s = "/s"
    local f = ""
    if n >= 1e12 then f = string.format("%.1f", n/1e12) s = "T/s"
    elseif n >= 1e9 then f = string.format("%.1f", n/1e9) s = "B/s"
    elseif n >= 1e6 then f = string.format("%.1f", n/1e6) s = "M/s"
    elseif n >= 1e3 then f = string.format("%.1f", n/1e3) s = "K/s"
    else f = tostring(math.floor(n)) end
    local l, r = f:match("^(%d+)(%.?%d*)$")
    l = l:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    return "$" .. l .. r .. s
end

