-- 6. 便利関数（数値変換）
local function formatVal(v)
    local n = tonumber(v) or 0
    local s = "" -- デフォルトでは単位なし
    local f = ""
    if n >= 1e12 then f = string.format("%.1f", n/1e12) s = "T"
    elseif n >= 1e9 then f = string.format("%.1f", n/1e9) s = "B"
    elseif n >= 1e6 then f = string.format("%.1f", n/1e6) s = "M"
    elseif n >= 1e3 then f = string.format("%.1f", n/1e3) s = "K"
    else f = tostring(math.floor(n)) end

    -- 小数点以下が0の場合、整数として表示
    if f:sub(#f, #f) == "." then f = f:sub(1, #f - 1) end
    if f:find("%.0$") then f = f:gsub("%.0$", "") end

    local l, r_match = f:match("^(%d+)(%.?%d*)$")
    l = l:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    local formatted_num = l .. r_match
    return "$" .. formatted_num .. s -- "$123.4K" のような形式
end

-- 7. スキャン処理（キャラ名・数値）
local function updateScanner()
    -- 既存のアイテムを削除
    for _, v in pairs(scanPage:GetChildren()) do
        if v:IsA("Frame") or v:IsA("TextLabel") then -- TextLabelも削除対象に含める場合
            v:Destroy()
        end
    end
    
    local playersData = {}

    for _, p in ipairs(game.Players:GetPlayers()) do
        if p == game.Players.LocalPlayer then continue end -- 自分自身はスキップ
        
        local cashVal = 0
        -- PlayerのDescendantsを直接ループする方が効率的
        for _, obj in ipairs(p:GetDescendants()) do
            -- objがValueBaseで、かつ特定の名前を含む場合
            if obj:IsA("ValueBase") and (obj.Name:find("PerSec") or obj.Name:find("Gain") or obj.Name:find("Brainrot")) then
                cashVal = obj.Value
                break -- 最初に見つかった値を使用
            end
        end
        table.insert(playersData, {player = p, value = cashVal})
    end

    -- 値の大きい順にソート（任意）
    table.sort(playersData, function(a, b)
        return a.value > b.value
    end)

    for _, data in ipairs(playersData) do
        local p = data.player
        local cashVal = data.value

        local f = Instance.new("Frame", scanPage)
        f.Size = UDim2.new(1, -5, 0, 35) -- 幅は親の100%から5px縮小, 高さは35px固定
        f.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        Instance.new("UICorner", f)
        
        local nameL = Instance.new("TextLabel", f)
        nameL.Size = UDim2.new(0.5, -5, 1, 0) -- 親フレームの半分、左右に5pxの余白
        nameL.Position = UDim2.new(0, 10, 0, 0) -- 左から10pxオフセット
        nameL.Text = p.DisplayName -- キャラ名を表示
        nameL.TextColor3 = Color3.new(1, 1, 1)
        nameL.BackgroundTransparency = 1
        nameL.TextXAlignment = Enum.TextXAlignment.Left
        nameL.TextTruncate = Enum.TextTruncate.AtEnd
        nameL.Font = Enum.Font.SourceSansBold
        nameL.TextSize = 14
        
        local valL = Instance.new("TextLabel", f)
        valL.Size = UDim2.new(0.5, -10, 1, 0) -- 親フレームの半分、左右に10pxの余白
        valL.Position = UDim2.new(0.5, 0, 0, 0) -- 右半分に配置
        valL.Text = formatVal(cashVal) -- formatVal関数を使って値を表示
        valL.TextColor3 = Color3.new(1, 1, 1)
        valL.BackgroundTransparency = 1
        valL.TextXAlignment = Enum.TextXAlignment.Right
        valL.TextTruncate = Enum.TextTruncate.AtEnd
        valL.Font = Enum.Font.SourceSans
        valL.TextSize = 14
    end
end

