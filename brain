-- 重複削除
for _, old in pairs(game.CoreGui:GetChildren()) do
    if old.Name == "ServerExplorerV12" then old:Destroy() end
end

local screenGui = Instance.new("ScreenGui", game.CoreGui)
screenGui.Name = "ServerExplorerV12"

-- メインパネル（右寄せ）
local panel = Instance.new("Frame", screenGui)
panel.Size = UDim2.new(0, 320, 0, 420)
panel.Position = UDim2.new(1, -330, 0.5, -210)
panel.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
panel.ClipsDescendants = true
Instance.new("UICorner", panel)

-- ヘッダー
local header = Instance.new("Frame", panel)
header.Size = UDim2.new(1, 0, 0, 50)
header.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
local title = Instance.new("TextLabel", header)
title.Size = UDim2.new(1, 0, 1, 0)
title.Text = "ACTIVE SERVER LIST"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextSize = 16
title.Font = Enum.Font.SourceSansBold
title.BackgroundTransparency = 1

-- スクロールリスト
local scroll = Instance.new("ScrollingFrame", panel)
scroll.Size = UDim2.new(1, -10, 1, -120)
scroll.Position = UDim2.new(0, 5, 0, 55)
scroll.BackgroundTransparency = 1
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.ScrollBarThickness = 5
local layout = Instance.new("UIListLayout", scroll)
layout.Padding = UDim.new(0, 6)

-- 更新ボタン
local refreshBtn = Instance.new("TextButton", panel)
refreshBtn.Size = UDim2.new(0.9, 0, 0, 40)
refreshBtn.Position = UDim2.new(0.05, 0, 0.88, 0)
refreshBtn.Text = "サーバー情報を更新"
refreshBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
refreshBtn.TextColor3 = Color3.new(1, 1, 1)
refreshBtn.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", refreshBtn)

-- サービス
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local function updateList()
    -- リストをクリア
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    
    refreshBtn.Text = "スキャン中..."
    refreshBtn.Active = false

    -- 公開サーバーリストを取得（最新順・50件）
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=50"
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)

    if success and result.data then
        for _, server in pairs(result.data) do
            -- 自分と同じサーバーはスキップ
            if server.id == game.JobId then continue end

            local freeSlots = server.maxPlayers - server.playing
            
            -- サーバー枠作成
            local f = Instance.new("Frame", scroll)
            f.Size = UDim2.new(1, -10, 0, 65)
            f.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            Instance.new("UICorner", f)

            -- ステータスラベル
            local info = Instance.new("TextLabel", f)
            info.Size = UDim2.new(0.65, 0, 1, 0)
            info.Position = UDim2.new(0, 10, 0, 0)
            info.BackgroundTransparency = 1
            info.TextColor3 = Color3.new(1, 1, 1)
            info.TextXAlignment = Enum.TextXAlignment.Left
            info.TextSize = 13
            
            -- 人数によって色を変える
            local statusColor = (freeSlots > 0) and "lime" or "red"
            info.RichText = true
            info.Text = "<b>人数:</b> " .. server.playing .. "/" .. server.maxPlayers .. 
                        "\n<b>空き:</b> <font color='" .. statusColor .. "'>" .. freeSlots .. "人</font>" ..
                        "\n<b>PING:</b> " .. (server.ping or "---") .. "ms"

            -- JOINボタン
            local join = Instance.new("TextButton", f)
            join.Size = UDim2.new(0.28, 0, 0.6, 0)
            join.Position = UDim2.new(0.68, 0, 0.2, 0)
            join.Text = "JOIN"
            join.BackgroundColor3 = (freeSlots > 0) and Color3.fromRGB(0, 180, 80) or Color3.fromRGB(100, 100, 100)
            join.TextColor3 = Color3.new(1, 1, 1)
            join.Font = Enum.Font.SourceSansBold
            Instance.new("UICorner", join)

            if freeSlots > 0 then
                join.MouseButton1Click:Connect(function()
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id)
                end)
            else
                join.AutoButtonColor = false -- 満員なら反応させない
                join.Text = "FULL"
            end
        end
    end
    refreshBtn.Text = "サーバー情報を更新"
    refreshBtn.Active = true
end

refreshBtn.MouseButton1Click:Connect(updateList)
