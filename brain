--// TOGGLE UI
local function toggleUI(state)
    panel.Visible = true

    if state then
        TweenService:Create(panel, TweenInfo.new(0.25), {
            Position = UDim2.new(1,-10,0.5,0)
        }):Play()
    else
        TweenService:Create(panel, TweenInfo.new(0.25), {
            Position = UDim2.new(1,300,0.5,0)
        }):Play()
        task.wait(0.25)
        panel.Visible = false
    end

    openIcon.Visible = not state
end

openIcon.MouseButton1Click:Connect(function()
    toggleUI(true)
end)

closeBtn.MouseButton1Click:Connect(function()
    toggleUI(false)
end)

--// DRAG (モバイル)
local dragging, dragStart, startPos

openIcon.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = openIcon.Position
    end
end)

openIcon.InputChanged:Connect(function(input)
    if dragging then
        local delta = input.Position - dragStart
        openIcon.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

openIcon.InputEnded:Connect(function()
    dragging = false
end)

--// SERVER FETCH
local function fetchServers(cursor)
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?limit=100"
    if cursor then url = url.."&cursor="..cursor end

    local ok,res = pcall(function()
        return game:HttpGet(url)
    end)

    if not ok then return nil end
    return HttpService:JSONDecode(res)
end

--// GET SERVERS
local function getServers()
    local servers = {}
    local cursor

    for _=1,MAX_PAGES do
        local data = fetchServers(cursor)
        if not data then break end

        for _,s in ipairs(data.data) do
            local free = s.maxPlayers - s.playing
            if free >= SAFE_SLOTS then
                table.insert(servers, s)
            end
        end

        cursor = data.nextPageCursor
        if not cursor then break end
    end

    return servers
end

--// FILTER
local function filterServers(list)
    local result = {}

    for _,s in ipairs(list) do
        local free = s.maxPlayers - s.playing

        if free >= SAFE_SLOTS
        and s.playing <= MAX_PLAYERS_ALLOWED
        and (not s.ping or s.ping <= MAX_PING) then
            table.insert(result, s)
        end
    end

    table.sort(result,function(a,b)
        return a.playing < b.playing
    end)

    return result
end

--// PICK
local function pickServer(list)
    if #list == 0 then return nil end
    return list[math.random(1, math.min(RANDOM_TOP,#list))]
end

--// TELEPORT
local function tryTeleport(server)
    return pcall(function()
        TeleportService:TeleportToPlaceInstance(placeId, server.id, player)
    end)
end

--// AUTO JOIN
local running = false

local function autoJoin()
    for i=1,MAX_RETRIES do
        local servers = filterServers(getServers())

        if #servers > 0 then
            local s = pickServer(servers)
            if tryTeleport(s) then return end
        end

        task.wait(RETRY_DELAY)
    end
end

local function startAuto()
    if running then return end
    running = true

    task.spawn(function()
        while running do
            autoJoin()
            task.wait(3)
        end
    end)
end

local function stopAuto()
    running = false
end

