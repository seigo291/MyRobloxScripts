-- 補助関数
local function getMult(txt) return (txt == "B/s") and 10^9 or 10^6 end

-- 数値をあらゆる場所から探す関数
local function findValue(player)
    -- 探す場所のリスト
    local targets = {
        player:FindFirstChild("leaderstats"),
        player:FindFirstChild("Data"),
        player:FindFirstChild("Stats"),
        player:FindFirstChild("PlayerGui")
    }
    
    for _, folder in pairs(targets) do
        if folder then
            -- 「PerSec」「Rate」「Brainrot」「Gain」「Value」という文字が含まれる数値を探す
            for _, v in pairs(folder:GetDescendants()) do
                if (v:IsA("NumberValue") or v:IsA("IntValue")) then
                    if v.Name:match("PerSec") or v.Name:match("Rate") or v.Name:match("Brain") or v.Name:match("Gain") then
                        return tonumber(v.Value)
                    end
                end
            end
        end
    end
    return nil
end

scanBtn.MouseButton1Click:Connect(function()
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") or v:IsA("TextLabel") then v:Destroy() end end
    
    local minVal = (tonumber(minIn.Text) or 0) * getMult(minUnit.Text)
    local maxVal = (tonumber(maxIn.Text) or 9e18) * getMult(maxUnit.Text)
    
    local foundCount = 0
    for _, p in ipairs(game.Players:GetPlayers()) do
        local val = findValue(p)
        
        -- 数値が見つかり、かつ範囲内なら表示
        if val and val >= minVal and val <= maxVal then
            foundCount = foundCount + 1
            local f = Instance.new("Frame", scroll)
            f.Size = UDim2.new(0.95, 0, 0, 50)
            f.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            Instance.new("UICorner", f)

            local t = Instance.new("TextLabel", f)
            t.Size = UDim2.new(0.7, 0, 1, 0)
            t.Position = UDim2.new(0.05, 0, 0, 0)
            t.BackgroundTransparency = 1
            t.TextColor3 = Color3.new(1, 1, 1)
            t.TextXAlignment = Enum.TextXAlignment.Left
            
            local display = val >= 10^9 and string.format("%.1f B/s", val/10^9) or string.format("%.1f M/s", val/10^6)
            t.Text = p.Name .. "\nRate: " .. display
        end
    end
    
    if foundCount == 0 then
        local err = Instance.new("TextLabel", scroll)
        err.Size = UDim2.new(1, 0, 0, 40)
        err.Text = "No players found. Try clearing Min/Max."
        err.TextColor3 = Color3.new(1, 0.4, 0.4)
        err.BackgroundTransparency = 1
    end
end)

