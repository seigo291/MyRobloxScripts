-- 数値のカンマ区切りと単位変換
local function formatNum(v)
    local formatted
    local suffix = "/s"
    if v >= 1e9 then 
        formatted = string.format("%.1f", v/1e9)
        suffix = "B/s"
    elseif v >= 1e6 then 
        formatted = string.format("%.1f", v/1e6)
        suffix = "M/s"
    elseif v >= 1e3 then 
        formatted = string.format("%.1f", v/1e3)
        suffix = "K/s"
    else 
        formatted = tostring(math.floor(v))
    end
    
    -- カンマを入れる処理
    local k
    while true do
        formatted, k = string.gsub(formatted, "^(-?%d+)(%d%d%d)", '%1,%2')
        if k == 0 then break end
    end
    return formatted .. suffix
end

-- プレイヤーの数値データを徹底的に探す関数
local function findCashValue(p)
    local stats = p:FindFirstChild("leaderstats")
    local foundVal = 0
    
    -- 探しに行く場所のリスト
    local searchIn = {stats, p}
    local keywords = {"PerSec", "Gain", "Rate", "Brainrot", "Income", "Cash"}
    
    for _, folder in pairs(searchIn) do
        if folder then
            for _, obj in pairs(folder:GetChildren()) do
                if obj:IsA("ValueBase") then
                    for _, key in pairs(keywords) do
                        if obj.Name:lower():find(key:lower()) then
                            return obj.Value
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function updateScan()
    for _, v in pairs(scanPage:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    
