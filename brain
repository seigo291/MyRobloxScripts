--// SERVICES
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local placeId = game.PlaceId

--// SETTINGS（ここ調整）
local MAX_PAGES = 5
local SAFE_SLOTS = 2
local RETRY_DELAY = 1.5
local MAX_RETRIES = 15
local RANDOM_TOP = 5

-- スナイプ条件
local MAX_PLAYERS_ALLOWED = 6 -- 過疎狙い
local MAX_PING = 120 -- ping制限（nilなら無視）

--// FETCH SERVER
local function fetchServers(cursor)
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Desc&limit=100"
    if cursor then
        url = url .. "&cursor=" .. cursor
    end

    local success, res = pcall(function()
        return game:HttpGet(url)
    end)

    if not success then return nil end
    return HttpService:JSONDecode(res)
end

--// GET SERVERS
local function getServers()
    local servers = {}
    local cursor = nil

    for _ = 1, MAX_PAGES do
        local data = fetchServers(cursor)
        if not data or not data.data then break end

        for _, s in ipairs(data.data) do
            local free = s.maxPlayers - s.playing

            if free >= SAFE_SLOTS then
                table.insert(servers, s)
            end
        end

        cursor = data.nextPageCursor
        if not cursor then break end
    end

    return servers
end

--// FILTER（スナイプ）
local function filterServers(list)
    local result = {}

    for _, s in ipairs(list) do
        local free = s.maxPlayers - s.playing

        if free >= SAFE_SLOTS
        and s.playing <= MAX_PLAYERS_ALLOWED
        and (not s.ping or s.ping <= MAX_PING) then
            table.insert(result, s)
        end
    end

    table.sort(result, function(a, b)
        return a.playing < b.playing
    end)

    return result
end

--// PICK
local function pickServer(list)
    if #list == 0 then return nil end
    local range = math.min(RANDOM_TOP, #list)
    return list[math.random(1, range)]
end

--// TELEPORT
local function tryTeleport(server)
    local success = pcall(function()
        TeleportService:TeleportToPlaceInstance(placeId, server.id, player)
    end)

    return success
end

--// AUTO JOIN
local function autoJoin()
    for i = 1, MAX_RETRIES do
        print("試行:", i)

        local servers = getServers()
        local filtered = filterServers(servers)

        if #filtered == 0 then
            warn("条件一致なし 再試行")
            task.wait(RETRY_DELAY)
            continue
        end

        local target = pickServer(filtered)

        if target then
            print("JOIN:", target.id, "人数:", target.playing)

            if tryTeleport(target) then
                return
            end
        end

        task.wait(RETRY_DELAY)
    end

    warn("全試行失敗")
end

--// LOOP
local running = false

local function startAuto()
    if running then return end
    running = true

    task.spawn(function()
        while running do
            autoJoin()
            task.wait(3)
        end
    end)
end

local function stopAuto()
    running = false
end

