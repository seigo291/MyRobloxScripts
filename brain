autoBtn.MouseButton1Click:Connect(function()
    toggle = not toggle

    if toggle then
        autoBtn.Text = "STOP"
        autoBtn.BackgroundColor3 = Color3.fromRGB(180,80,80)
        startAuto()
    else
        autoBtn.Text = "AUTO SNIPE"
        autoBtn.BackgroundColor3 = Color3.fromRGB(80,160,80)
        stopAuto()
    end
end)

--// 手動リスト表示（既存のrefreshServers強化版）
local function refreshServers()
    for _, v in pairs(servPage:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end

    local servers = getServers()

    for _, s in ipairs(servers) do
        local f = Instance.new("Frame", servPage)
        f.Size = UDim2.new(1, -5, 0, 40)
        f.BackgroundColor3 = Color3.fromRGB(45,45,45)
        Instance.new("UICorner", f)

        local txt = Instance.new("TextLabel", f)
        txt.Size = UDim2.new(0.7, 0, 1, 0)
        txt.Position = UDim2.new(0, 10, 0, 0)
        txt.BackgroundTransparency = 1
        txt.TextXAlignment = Enum.TextXAlignment.Left
        txt.Font = Enum.Font.SourceSans
        txt.TextSize = 13
        txt.TextColor3 = Color3.new(1,1,1)

        txt.Text = "👥 "..s.playing.."/"..s.maxPlayers

        local btn = Instance.new("TextButton", f)
        btn.Size = UDim2.new(0.25, 0, 0.7, 0)
        btn.Position = UDim2.new(0.72, 0, 0.15, 0)
        btn.Text = "JOIN"
        btn.BackgroundColor3 = Color3.fromRGB(70,130,255)
        btn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", btn)

        btn.MouseButton1Click:Connect(function()
            tryTeleport(s)
        end)
    end
end

