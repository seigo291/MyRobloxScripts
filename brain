-- 単位変換（●,●M/s 形式）
local function formatVal(v)
    local n = tonumber(v) or 0
    local suffix = "/s"
    local formatted = ""
    
    if n >= 1e9 then
        formatted = string.format("%.1f", n/1e9)
        suffix = "B/s"
    elseif n >= 1e6 then
        formatted = string.format("%.1f", n/1e6)
        suffix = "M/s"
    elseif n >= 1e3 then
        formatted = string.format("%.1f", n/1e3)
        suffix = "K/s"
    else
        formatted = tostring(math.floor(n))
    end
    
    -- 3桁カンマ区切り
    local left, right = formatted:match("^(%d+)(%.?%d*)$")
    left = left:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    return "$" .. left .. right .. suffix
end

-- プレイヤーの全フォルダから「稼ぎ」を探す
local function getMoney(p)
    local keywords = {"PerSec", "Gain", "Brainrot", "Income", "Cash"}
    -- プレイヤー内のすべてのValueオブジェクトを確認
    for _, obj in pairs(p:GetDescendants()) do
        if obj:IsA("ValueBase") then
            for _, key in pairs(keywords) do
                if obj.Name:lower():find(key:lower()) then
                    return obj.Value
                end
            end
        end
    end
    return 0
end

local function runScan()
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    
    local players = game.Players:GetPlayers()
    for _, p in ipairs(players) do
        if p == game.Players.LocalPlayer then continue end
        
        local val = getMoney(p)
        
        local f = Instance.new("Frame", scroll)
