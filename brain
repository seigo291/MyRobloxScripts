-- 通信・スキャン処理
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local function runScan()
    for _, v in pairs(scanScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    local minV = tonumber(minIn.Text) or 0
    local found = 0
    
    for _, p in ipairs(game.Players:GetPlayers()) do
        -- 数値の取得（複数の可能性をチェック）
        local stats = p:FindFirstChild("leaderstats")
        local valObj = stats and (stats:FindFirstChild("BrainrotPerSec") or stats:FindFirstChild("Gain") or stats:FindFirstChild("Cash") or stats:FindFirstChild("Multiplier"))
        
        if valObj then
            local val = tonumber(tostring(valObj.Value):gsub("[^%d%.]", "")) or 0
            if val >= minV then
                found = found + 1
                local f = Instance.new("Frame", scanScroll)
                f.Size = UDim2.new(1, 0, 0, 30)
                f.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                local t = Instance.new("TextLabel", f)
                t.Size = UDim2.new(1, -5, 1, 0)
                t.Text = p.Name .. ": " .. valObj.Value
                t.TextColor3 = Color3.new(1, 1, 1)
                t.TextSize = 9
                t.BackgroundTransparency = 1
            end
        end
    end
    
    -- ターゲットなし ＆ 自動巡回ONなら移動
    if found == 0 and _G.AutoScanEnabled then
        refBtn.Text = "AUTO HOPPING..."
        local success, res = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=20"))
        end)
        if success and res.data then
            for _, s in pairs(res.data) do
                if s.playing < s.maxPlayers and s.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id)
                    break
                end
            end
        end
    end
end

-- タブ切り替え
tabScan.MouseButton1Click:Connect(function() scanPage.Visible = true servPage.Visible = false end)
tabServ.MouseButton1Click:Connect(function() scanPage.Visible = false servPage.Visible = true end)

autoBtn.MouseButton1Click:Connect(function()
    _G.AutoScanEnabled = not _G.AutoScanEnabled
    autoBtn.Text = _G.AutoScanEnabled and "AUTO: ON" or "AUTO: OFF"
    autoBtn.BackgroundColor3 = _G.AutoScanEnabled and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(60, 60, 60)
    if _G.AutoScanEnabled then runScan() end
end)

refBtn.MouseButton1Click:Connect(function()
    for _, v in pairs(servScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    refBtn.Text = "LOADING..."
    local success, res = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=15"))
    end)
    
    if success and res.data then
        for _, s in pairs(res.data) do
            local f = Instance.new("Frame", servScroll)
            f.Size = UDim2.new(1, 0, 0, 35)
            f.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            local t = Instance.new("TextLabel", f)
            t.Size = UDim2.new(0.6, 0, 1, 0)
            t.Text = s.playing.."/"..s.maxPlayers.." ("..(s.ping or "?").."ms)"
            t.TextColor3 = Color3.new(1, 1, 1)
            t.TextSize = 9
            t.BackgroundTransparency = 1
            local j = Instance.new("TextButton", f)
            j.Size = UDim2.new(0.3, 0, 0.7, 0)
            j.Position = UDim2.new(0.65, 0, 0.15, 0)
            j.Text = "JOIN"
            j.BackgroundColor3 = Color3.fromRGB(0, 120, 50)
            j.TextColor3 = Color3.new(1, 1, 1)
            j.TextSize = 9
            j.MouseButton1Click:Connect(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id) end)
        end
    else
        refBtn.Text = "RETRYING..."
    end
    refBtn.Text = "REFRESH"
end)

-- 起動時の処理
if _G.AutoScanEnabled then
    task.wait(5) -- 読み込み待ちを5秒に延長
    runScan()
end
